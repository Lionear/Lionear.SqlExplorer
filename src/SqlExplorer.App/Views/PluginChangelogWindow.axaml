<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlExplorer.App.ViewModels"
        x:Class="SqlExplorer.App.Views.PluginChangelogWindow"
        x:DataType="vm:PluginChangelogViewModel"
        Title="{Binding Title}"
        Width="560" Height="560" MinWidth="440" MinHeight="320"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="20">

    <!-- Footer: close only. -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
      <Button Grid.Column="1" Content="{Binding Loc[Close]}" Click="OnClose" />
    </Grid>

    <!-- One section per plugin (heading + markdown notes), populated in code-behind. -->
    <Border Background="{DynamicResource SEPanelBgBrush}" Padding="14,12"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
      <ScrollViewer x:Name="Scroller" HorizontalScrollBarVisibility="Disabled">
        <!-- Cap the content width to the scroll viewport so long notes wrap. A bare StackPanel of TextBlocks
             doesn't get a finite width from a horizontal-scroll-disabled ScrollViewer the way a Grid '*'
             column does (Avalonia 12), so without this the text runs past the right edge. Bind to Bounds
             (set by the parent, stable) — Viewport is circular here and never resolves; padding lives on the
             Border so Bounds.Width equals the usable content width (Fluent scrollbars overlay). -->
        <StackPanel x:Name="SectionsHost" Spacing="14" MaxWidth="{Binding #Scroller.Bounds.Width}" />
      </ScrollViewer>
    </Border>

  </DockPanel>
</Window>
