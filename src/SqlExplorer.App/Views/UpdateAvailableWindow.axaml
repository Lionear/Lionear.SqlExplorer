<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlExplorer.App.ViewModels"
        x:Class="SqlExplorer.App.Views.UpdateAvailableWindow"
        x:DataType="vm:UpdateAvailableViewModel"
        Title="{Binding Loc[UpdateDialogTitle]}"
        Width="560" Height="580" MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="20">

    <!-- Header: version, date, commit -->
    <StackPanel DockPanel.Dock="Top" Spacing="3" Margin="0,0,0,12">
      <TextBlock Text="{Binding VersionLine}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
      <TextBlock Text="{Binding PublishedLine}" IsVisible="{Binding HasPublished}" TextWrapping="Wrap"
                 FontSize="11.5" Foreground="{DynamicResource SETextSecondaryBrush}" />
      <TextBlock Text="{Binding CommitLine}" IsVisible="{Binding HasCommit}" TextWrapping="Wrap"
                 FontSize="11.5" Foreground="{DynamicResource SETextFaintBrush}"
                 FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
    </StackPanel>

    <!-- Footer: close only. Download/install live in the main-window banner now (SE-151). -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
      <Button Grid.Column="1" Content="{Binding Loc[Close]}" Click="OnClose" />
    </Grid>

    <!-- Release notes (rendered from markdown in code-behind) -->
    <Border Background="{DynamicResource SEPanelBgBrush}" Padding="14,12"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
      <ScrollViewer x:Name="Scroller" HorizontalScrollBarVisibility="Disabled">
        <!-- Cap the content width to the scroll viewport so long notes wrap (see PluginChangelogWindow):
             a bare content host doesn't get a finite width from a horizontal-scroll-disabled ScrollViewer
             in Avalonia 12, so without this the text runs past the right edge. Bind to Bounds (stable, set
             by the parent); padding lives on the Border so Bounds.Width equals the usable content width. -->
        <Border x:Name="NotesHost" MaxWidth="{Binding #Scroller.Bounds.Width}" />
      </ScrollViewer>
    </Border>

  </DockPanel>
</Window>
