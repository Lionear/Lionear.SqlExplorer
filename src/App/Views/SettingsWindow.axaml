<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:Lionear.SqlExplorer.App.Converters"
        xmlns:settings="using:Lionear.SqlExplorer.Core.Settings"
        x:Class="Lionear.SqlExplorer.App.Views.SettingsWindow"
        Title="{Binding Loc[Preferences]}"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16" RowDefinitions="*,Auto" ColumnDefinitions="140,*">

    <ListBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,0"
             ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding}" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10"
                IsVisible="{Binding SelectedCategory, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=General}">
      <TextBlock Text="{Binding Loc[Language]}" FontWeight="SemiBold" />
      <TextBlock Text="{Binding Loc[SettingsGeneral]}" FontSize="12" Foreground="{DynamicResource CatTextSecondaryBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="12">
        <RadioButton GroupName="Language" Content="Nederlands"
                     IsChecked="{Binding Language, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=nl, Mode=OneWay}"
                     Command="{Binding SetLanguageCommand}" CommandParameter="nl" />
        <RadioButton GroupName="Language" Content="English"
                     IsChecked="{Binding Language, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=en, Mode=OneWay}"
                     Command="{Binding SetLanguageCommand}" CommandParameter="en" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10"
                IsVisible="{Binding SelectedCategory, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Appearance}">
      <TextBlock Text="{Binding Loc[Theme]}" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Spacing="12">
        <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeSystem]}"
                     IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.System}, Mode=OneWay}"
                     Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.System}" />
        <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeLight]}"
                     IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.Light}, Mode=OneWay}"
                     Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.Light}" />
        <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeDark]}"
                     IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.Dark}, Mode=OneWay}"
                     Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.Dark}" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10"
                IsVisible="{Binding SelectedCategory, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Editor}">
      <TextBlock Text="{Binding Loc[SettingsEditor]}" FontWeight="SemiBold" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding Loc[EditorFontSize]}" VerticalAlignment="Center" />
        <NumericUpDown Grid.Column="1" Width="100" Minimum="8" Maximum="32"
                        Value="{Binding EditorFontSize}" />
      </Grid>
      <CheckBox Content="{Binding Loc[EditorWordWrap]}" IsChecked="{Binding EditorWordWrap}" />
    </StackPanel>

    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10"
                IsVisible="{Binding SelectedCategory, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Query}">
      <TextBlock Text="{Binding Loc[SettingsQuery]}" FontWeight="SemiBold" />
      <CheckBox Content="{Binding Loc[ConfirmBeforeSave]}" IsChecked="{Binding ConfirmBeforeSave}" />
    </StackPanel>

    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,16,0,0"
          ColumnDefinitions="Auto,*,Auto,Auto,Auto">
      <Button Grid.Column="0" Classes="Subtle" Content="{Binding Loc[RestoreDefaults]}" Command="{Binding RestoreDefaultsCommand}" />
      <Button Grid.Column="2" Classes="Subtle" Content="{Binding Loc[Cancel]}" Command="{Binding CancelCommand}" Margin="0,0,8,0" />
      <Button Grid.Column="3" Content="{Binding Loc[Apply]}" Command="{Binding ApplyCommand}" Margin="0,0,8,0" />
      <Button Grid.Column="4" Classes="Accent" Content="{Binding Loc[ApplyAndClose]}" Command="{Binding ApplyAndCloseCommand}" IsDefault="True" />
    </Grid>
  </Grid>
</Window>
