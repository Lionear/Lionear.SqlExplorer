<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Lionear.SqlExplorer.App.Views"
        x:Class="Lionear.SqlExplorer.App.Views.MainWindow"
        Title="Lionear SQL Explorer"
        Icon="/Assets/icon.png"
        Width="1150" Height="740">
  <!-- Quick-open shortcut lives on the window (not MainView): with nothing focused yet, a keypress
       is delivered to the TopLevel itself, so a UserControl-level KeyBinding would never see it. -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleSearchCommand}" />
    <KeyBinding Gesture="F5" Command="{Binding RunActiveDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+Enter" Command="{Binding RunActiveDocumentAtCursorCommand}" />
  </Window.KeyBindings>

  <!-- macOS gets its menu bar from NativeMenu.Menu below (native, always active regardless of OS —
       Avalonia only surfaces it on macOS); the in-window Menu here is hidden there in code-behind
       so the two never show up stacked on top of each other. -->
  <!-- Mirror the in-window File/Edit/Help menu below. macOS only surfaces top-level NativeMenuItems
       that carry their own submenu as menu-bar entries, so flat items would silently vanish. -->
  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="{Binding Loc[MenuFile]}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="{Binding Loc[NewQueryTab]}" Command="{Binding NewQueryTabCommand}" />
            <NativeMenuItem Header="{Binding Loc[NewConnectionMenu]}" Command="{Binding NewConnectionCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="{Binding Loc[Exit]}" Command="{Binding ExitCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
      <NativeMenuItem Header="{Binding Loc[MenuEdit]}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="{Binding Loc[Preferences]}" Command="{Binding OpenSettingsCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
      <NativeMenuItem Header="{Binding Loc[MenuHelp]}">
        <NativeMenuItem.Menu>
          <NativeMenu>
            <NativeMenuItem Header="{Binding Loc[About]}" Command="{Binding ShowAboutCommand}" />
          </NativeMenu>
        </NativeMenuItem.Menu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <DockPanel>
    <Menu x:Name="AppMenu" DockPanel.Dock="Top">
      <MenuItem Header="{Binding Loc[MenuFile]}">
        <MenuItem Header="{Binding Loc[NewQueryTab]}" Command="{Binding NewQueryTabCommand}" />
        <MenuItem Header="{Binding Loc[NewConnectionMenu]}" Command="{Binding NewConnectionCommand}" />
        <Separator />
        <MenuItem Header="{Binding Loc[Exit]}" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="{Binding Loc[MenuEdit]}">
        <MenuItem Header="{Binding Loc[Preferences]}" Command="{Binding OpenSettingsCommand}" />
      </MenuItem>
      <MenuItem Header="{Binding Loc[MenuHelp]}">
        <MenuItem Header="{Binding Loc[About]}" Command="{Binding ShowAboutCommand}" />
      </MenuItem>
    </Menu>
    <views:MainView x:Name="Body" />
  </DockPanel>
</Window>
